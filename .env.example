# ─────────────────────────────────────────────
# RECAP Demo — API Keys Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# You only need the keys for the models you plan to use.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your keys
#   docker compose up --build
# ─────────────────────────────────────────────

# OpenAI (for GPT-5.4, GPT-4.1, etc.)
OPENAI_API_KEY=

# Google Gemini (for Gemini 3 Flash-Lite, Gemini 2.5, etc.)
GEMINI_API_KEY=

# Anthropic (for Claude models)
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
